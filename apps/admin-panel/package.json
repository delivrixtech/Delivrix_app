{
  "name": "@delivrix/admin-panel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only Delivrix admin panel shell.",
  "author": "JECT",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:force": "VITE_FORCE_OPTIMIZE=1 vite --host 127.0.0.1 --port 5173 --force",
    "build": "tsc --noEmit && vite build",
    "serve": "node server.mjs",
    "check": "tsc --noEmit && node --check server.mjs && node --test src/shared/api/client.test.ts src/shared/lib/formatters.test.ts src/shared/lib/domain-state-copy.test.ts src/shared/ui/realtime/realtime.test.ts src/features/cleanup-fallbacks.test.ts src/features/chat/ChatWidget.test.ts && vite build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/funnel-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.9",
    "@vitejs/plugin-react": "^6.0.1",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
