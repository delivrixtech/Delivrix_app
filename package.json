  "scripts": {
    "test": "node --test packages/domain/src/*.test.ts packages/domain/src/runbooks/*.test.ts packages/adapters/src/*.test.ts apps/gateway-api/src/**/*.test.ts",
    "test:admin": "npm --workspace @delivrix/admin-panel run check",
    "dev:gateway": "node apps/gateway-api/src/main.ts",
    "dev:worker": "node apps/worker/src/main.ts",
    "dev:admin": "npm --workspace @delivrix/admin-panel run dev",
    "serve:admin": "npm --workspace @delivrix/admin-panel run serve"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
