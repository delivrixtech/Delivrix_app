NODE_ENV=development
GATEWAY_PORT=3000
GATEWAY_HOST=127.0.0.1
DELIVRIX_BASE_URL=http://gateway.delivrix.local:3000
DELIVRIX_OPENCLAW_TOKEN=replace_with_read_boundary_token
OPENCLAW_AGENT_HTTP_URL=http://2.24.223.240:61175
OPENCLAW_AGENT_WS_URL=ws://2.24.223.240:61175/api/chat.stream
OPENCLAW_GATEWAY_TOKEN=replace_with_openclaw_gateway_token
DELIVRIX_PHYSICAL_ADDRESS="Delivrix LLC physical mailing address"
DATABASE_URL=postgres://delivrix:delivrix_dev_password@127.0.0.1:5432/delivrix_mailops
REDIS_URL=redis://127.0.0.1:6379
LOCAL_SEND_QUEUE_FILE=runtime/send-jobs.json
LOCAL_AUDIT_LOG_FILE=runtime/audit-events.json
LOCAL_SUPPRESSION_FILE=runtime/suppression-entries.json
LOCAL_SENDER_NODES_FILE=runtime/sender-nodes.json
LOCAL_RATE_LIMIT_COUNTERS_FILE=runtime/rate-limit-counters.json
LOCAL_SEND_RESULTS_FILE=runtime/send-results.json
LOCAL_KILL_SWITCH_FILE=runtime/kill-switch.json
RATE_LIMIT_CAMPAIGN_DAILY=100
RATE_LIMIT_SENDER_DOMAIN_DAILY=300
RATE_LIMIT_RECIPIENT_DOMAIN_DAILY=100

# AWS Route53 Domains - Fase 1 discover/propose (NO compra)
AWS_ROUTE53_REGION=us-east-1
AWS_ROUTE53_ACCESS_KEY_ID=<from ~/.aws-secrets/delivrix-route53-keys.txt>
AWS_ROUTE53_SECRET_ACCESS_KEY=<from ~/.aws-secrets/delivrix-route53-keys.txt>
AWS_ROUTE53_CACHE_TTL_MS=300000
AWS_ROUTE53_DOMAINS_ENABLE_PURCHASE=false
