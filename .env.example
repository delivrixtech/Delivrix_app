NODE_ENV=development
GATEWAY_PORT=3000
GATEWAY_HOST=127.0.0.1
DELIVRIX_BASE_URL=http://gateway.delivrix.local:3000
DELIVRIX_OPENCLAW_TOKEN=replace_with_read_boundary_token
DELIVRIX_READ_BOUNDARY_TOKEN=replace_with_read_boundary_token
OPENCLAW_AGENT_HTTP_URL=http://2.24.223.240:61175
OPENCLAW_AGENT_WS_URL=ws://2.24.223.240:61175/api/chat.stream
OPENCLAW_GATEWAY_TOKEN=replace_with_openclaw_gateway_token
OPENCLAW_OPERATOR_HMAC_SECRET=replace_with_operator_memory_hmac_secret
# Orquestador SMTP autonomo (1 firma -> 14 pasos atomicos). Dejar en false para RESUMIR un run a medias
# (evita re-ejecucion desde cero / VPS duplicado); activar solo para dominio fresco de punta a punta.
OPENCLAW_CONFIGURE_COMPLETE_SMTP_ENABLE=false
# Live context de OpenClaw: maximo de runs SMTP persistidos visibles para resume/status.
OPENCLAW_ACTIVE_SMTP_RUNS_LIMIT=50
# Solo tests locales pueden saltar HMAC en memoria semantica; produ debe quedar false/ausente.
OPENCLAW_MEMORY_ALLOW_UNSIGNED_LOCAL=false
DELIVRIX_PHYSICAL_ADDRESS="Delivrix LLC physical mailing address"
POSTGRES_URL=postgres://delivrix:<postgres-password>@127.0.0.1:5432/delivrix_mailops
POSTGRES_CONTAINER=delivrix-postgres
REDIS_URL=redis://127.0.0.1:6379
LOCAL_SEND_QUEUE_FILE=runtime/send-jobs.json
# IMPORTANTE: el bridge espera JSONL hash-encadenado en .audit/, NO el array legacy runtime/audit-events.json
# (ese path rompe el audit chain y tumba el chat con "Unexpected token ]").
LOCAL_AUDIT_LOG_FILE=.audit/audit-events.jsonl
LOCAL_SUPPRESSION_FILE=runtime/suppression-entries.json
LOCAL_SENDER_NODES_FILE=runtime/sender-nodes.json
LOCAL_RATE_LIMIT_COUNTERS_FILE=runtime/rate-limit-counters.json
LOCAL_SEND_RESULTS_FILE=runtime/send-results.json
LOCAL_KILL_SWITCH_FILE=runtime/kill-switch.json
RATE_LIMIT_CAMPAIGN_DAILY=100
RATE_LIMIT_SENDER_DOMAIN_DAILY=300
RATE_LIMIT_RECIPIENT_DOMAIN_DAILY=100

# AWS Route53 Domains - Fase 1 discover/propose (NO compra)
AWS_ROUTE53_REGION=us-east-1
AWS_ROUTE53_ACCESS_KEY_ID=<from ~/.aws-secrets/delivrix-route53-keys.txt>
AWS_ROUTE53_SECRET_ACCESS_KEY=<from ~/.aws-secrets/delivrix-route53-keys.txt>
AWS_ROUTE53_CACHE_TTL_MS=300000
AWS_ROUTE53_DOMAINS_ENABLE_PURCHASE=false
# Flujo SMTP autonomo (activar en .env.local; cada accion real igual exige ApprovalGate firmado):
AWS_ROUTE53_DNS_ENABLE_WRITES=false
AWS_ROUTE53_DOMAINS_ENABLE_NAMESERVER_UPDATES=false

# Porkbun Domains - Fase 1 discover/propose (NO compra)
PORKBUN_API_KEY=<from ~/.porkbun-secrets/delivrix-keys.txt>
PORKBUN_SECRET_API_KEY=<from ~/.porkbun-secrets/delivrix-keys.txt>
PORKBUN_BASE_URL=https://api.porkbun.com/api/json/v3
PORKBUN_CACHE_TTL_MS=300000
PORKBUN_ENABLE_PURCHASE=false

# Demo viernes — Webdock/SMTP/warmup live gates.
SMTP_PROVISIONING_ENABLE_SSH=false
SMTP_PROVISION_SSH_USER=root
SMTP_PROVISION_SSH_KEY_PATH=~/.ssh/delivrix_demo
SMTP_PROVISION_SSH_TIMEOUT_MS=180000
CREDENTIAL_ENCRYPTION_KEY=replace_with_32_byte_base64url_or_hex_key
WEBDOCK_SSH_ACCESS_SETTLE_MS=120000
# bind FCrDNS + escritura SPF/DKIM/DMARC (activar en .env.local para flujo SMTP completo):
DOMAIN_BIND_ENABLE=false
EMAIL_AUTH_ENABLE_WRITES=false

# Warmup del inbox — gate del Acto 3 demo.
WARMUP_ENABLE_SEND=true
WARMUP_DEFAULT_SEED_INBOXES=seed-1@xxxxx.mailtrap.io,seed-2@xxxxx.mailtrap.io,seed-3@xxxxx.mailtrap.io
# Gate de compra de dominio (sin esto -> blocker monthly_cap_missing):
AWS_ROUTE53_DOMAINS_MONTHLY_CAP_USD=50
# Contacto admin Route53 (sin esto -> blocker admin_contact_missing). Formato: ver DOCUMENTACION/runbooks-demo-viernes/admin-contact-template.json
# Comillas SIMPLES externas para que node --env-file preserve las comillas dobles del JSON:
# DELIVRIX_ADMIN_CONTACT_JSON='{"FirstName":"...","LastName":"...","ContactType":"PERSON","AddressLine1":"...","City":"...","CountryCode":"CO","ZipCode":"...","PhoneNumber":"+57.XXXXXXXXXX","Email":"..."}'
# Smoke test (send_real_email). OJO: distinto de WARMUP_ENABLE_SEND (ese es para seed_warmup_pool):
SMTP_SEND_REAL_EMAIL_ENABLE=false
WARMUP_RAMP_ENABLE=false
OPENCLAW_PLAN_SIGNATURE_AUTONOMY_ENABLE=false
